{
    "compilerOptions": {
        "baseUrl": ".",
        "declaration": true,
        "lib": ["dom", "es2018"],
        "module": "esnext",
        "moduleResolution": "node",
        "strict": true,
        "target": "es2017",
        "skipLibCheck": true,
        "paths": {
            "@aws-rum-web/core": ["./packages/core/src"],
            "@aws-rum-web/core/*": ["./packages/core/src/*"],
            "@aws-rum-web/slim/*": ["./packages/aws-rum-slim/src/*"],
            "test-utils/*": ["./packages/core/src/test-utils/*"]
        }
    }
}
