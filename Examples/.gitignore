# Local environment — contains account IDs and per-developer overrides
.env.local
.env.*.local

# CFN-output-derived config consumed by the demo apps at runtime.
# Contains real IdentityPoolId / UserPoolId / UserPoolClientId for the
# deployer's account. Regenerate with `npm run write-configs` in Examples/infra.
**/public/config.local.js

# Matrix validation evidence — regenerated by scripts/validate-matrix.mjs
validate-matrix-results.json

# CDK build artifacts
infra/cdk.out/
infra/*.js
infra/*.d.ts
!infra/scripts/*.js
!infra/scripts/*.mjs

# Node
node_modules/
npm-debug.log*
*.tsbuildinfo

# Vite / build output
dist/
.vite/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
