{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "rootDir": "src",
        "noEmit": true,
        "paths": {
            "@aws-rum/web-core": ["../core/src"],
            "@aws-rum/web-core/*": ["../core/src/*"],
            "@aws-rum/web-slim/CommandQueue": ["../slim/src/CommandQueue"],
