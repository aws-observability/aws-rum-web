{
    "name": "aws-rum-web-monorepo",
    "version": "3.0.0",
    "private": true,
    "description": "The Amazon CloudWatch RUM web client monorepo.",
    "license": "Apache-2.0",
    "author": "Amazon CloudWatch RUM Staff <nobody@amazon.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/aws-observability/aws-rum-web.git"
    },
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "prepare": "husky install",
        "pretest": "npm run build:schemas",
        "test": "jest -c jest.unit.config.js",
        "test:coverage": "jest -c jest.unit.config.js --coverage",
        "server": "webpack serve --config packages/web/webpack/webpack.dev.js",
        "build:dev": "webpack --config packages/web/webpack/webpack.dev.js && webpack --config packages/slim/webpack/webpack.dev.js",
        "build:dev:full": "webpack --config packages/web/webpack/webpack.dev.js",
        "build:dev:slim": "webpack --config packages/slim/webpack/webpack.dev.js",
        "integ": "npm run build:dev && npx playwright test --config=playwright.integ.config.ts",
        "integ:full": "npm run integ -- --project=aws-rum-web:chromium",
        "integ:slim": "npm run integ -- --project=aws-rum-slim:chromium",
        "integ:chrome": "npm run integ -- --project=aws-rum-web:chromium --project=aws-rum-slim:chromium",
        "integ:firefox": "npm run integ -- --project=aws-rum-web:firefox --project=aws-rum-slim:firefox",
        "integ:webkit": "npm run integ -- --project=aws-rum-web:webkit --project=aws-rum-slim:webkit",
        "integ:edge": "npm run integ -- --project=aws-rum-web:msedge --project=aws-rum-slim:msedge",
        "prebuild": "npm run build:schemas",
        "build": "npm run build --workspace=packages/core && npm run build --workspace=packages/slim && npm run build --workspace=packages/web",
        "build:schemas": "node scripts/generate-schema-ts.js",
        "lint": "eslint --ext .ts packages/core/src/",
        "lint:errors": "npm run lint -- --quiet",
        "lint:fix": "npm run lint -- --fix",
        "prettier": "npx prettier --check .",
        "prettier:fix": "npm run prettier -- --write",
        "release": "npm run build",
        "smoke:headless": "cross-env URL=$URL MONITOR=$MONITOR ENDPOINT=$ENDPOINT NAME=$NAME VERSION=$npm_package_version INSTALL_METHOD=$INSTALL_METHOD MONITOR_ID_2=$MONITOR_ID_2 npx playwright test --config=playwright.config.ts",
        "smoke:local": "cross-env URL=$URL MONITOR=$MONITOR ENDPOINT=$ENDPOINT NAME=$NAME VERSION=$npm_package_version MONITOR_ID_2=$MONITOR_ID_2 npx playwright test --config=playwright.local.config.ts --headed",
        "smoke:local:headless": "cross-env URL=$URL MONITOR=$MONITOR ENDPOINT=$ENDPOINT NAME=$NAME VERSION=$npm_package_version MONITOR_ID_2=$MONITOR_ID_2 npx playwright test --config=playwright.local.config.ts",
        "stats": "node scripts/bundle-stats.js --both",
        "stats:full": "node scripts/bundle-stats.js --full",
        "stats:slim": "node scripts/bundle-stats.js --slim"
    },
    "devDependencies": {
        "@aws-sdk/client-rum": "^3.1029.0",
        "@playwright/test": "^1.57.0",
        "@types/jest": "^29.2.3",
        "@types/pako": "^2.0.4",
        "@types/shimmer": "^1.0.2",
        "@types/ua-parser-js": "^0.7.35",
        "@types/uuid": "^9.0.0",
        "@typescript-eslint/eslint-plugin": "^5.38.0",
        "@typescript-eslint/parser": "^5.38.0",
        "@webpack-cli/serve": "^3.0.1",
        "case-sensitive-paths-webpack-plugin": "^2.4.0",
        "copy-webpack-plugin": "^14.0.0",
        "copyfiles": "^2.4.1",
        "cross-env": "^7.0.3",
        "eslint": "^8.23.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.26.0",
        "eslint-plugin-jsdoc": "^39.3.6",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "eslint-plugin-react": "^7.31.8",
        "generate-json-webpack-plugin": "^2.0.0",
        "http-server": "^14.1.1",
        "husky": "^8.0.3",
        "jest": "^29.3.1",
        "jest-date-mock": "^1.0.8",
        "jest-environment-jsdom": "^30.2.0",
        "jest-environment-jsdom-global": "^4.0.0",
        "jest-mock-random": "^1.1.1",
        "jsdom": "^27.4.0",
        "json-schema-to-typescript": "^11.0.2",
        "lerna": "^9.0.0",
        "lint-staged": "^16.4.0",
        "lodash": "^4.18.1",
        "nightwatch": "^2.0.6",
        "node-fetch": "^2.6.1",
        "npm-run-all": "^4.1.5",
        "prettier": "2.8.4",
        "standard-version": "^9.3.2",
        "terser-webpack-plugin": "^5.3.10",
        "ts-jest": "^29.0.3",
        "ts-loader": "^9.4.2",
        "typescript": "^4.8.4",
        "web-streams-polyfill": "^3.1.0",
        "webpack": "^5.99.8",
        "webpack-bundle-analyzer": "^4.5.0",
        "webpack-cli": "^6.0.1",
        "webpack-dev-middleware": "^7.4.2",
        "webpack-dev-server": "^5.2.1",
        "webpack-merge": "^6.0.1",
        "xhr-mock": "^2.5.1"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{js,json,html,yml,md}": "prettier --write"
    },
    "browserslist": [
        "Chrome >= 55",
        "Firefox >= 52",
        "Safari >= 10.1",
        "Edge >= 15"
    ],
    "overrides": {
        "jest-environment-jsdom-global": {
            "jest-environment-jsdom": "$jest-environment-jsdom"
        }
    }
}
