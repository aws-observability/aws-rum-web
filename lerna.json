{
    "$schema": "node_modules/lerna/schemas/lerna-schema.json",
    "version": "3.0.0",
    "npmClient": "npm",
    "packages": ["packages/*"],
    "command": {
        "version": {
            "conventionalCommits": true,
            "changelogPreset": "angular",
            "createRelease": false,
            "push": false,
            "message": "chore(release): v%s",
            "allowBranch": ["main"],
            "exact": true,
            "forcePublish": "*"
        }
    }
}
